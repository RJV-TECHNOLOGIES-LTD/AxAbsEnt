    "plt.figure(figsize=(16, 12))\n",
    "\n",
    "# 1. Entropy Flow Visualization\n",
    "plt.subplot(2, 2, 1)\n",
    "entropy_values = [flow['entropy_loss'] for flow in entropy_flow]\n",
    "plt.bar(range(len(entropy_values)), entropy_values)\n",
    "plt.title(\"Entropy Loss Across Entity Interactions\")\n",
    "plt.xlabel(\"Entity Pair Index\")\n",
    "plt.ylabel(\"Entropy Loss (Δε)\")\n",
    "\n",
    "# 2. Tensor Norm Profiles\n",
    "plt.subplot(2, 2, 2)\n",
    "for idx, tensor_result in enumerate(tensor_interactions):\n",
    "    I_AB = tensor_result['I_AB']\n",
    "    plt.plot(np.linalg.norm(I_AB, axis=1), label=f\"Row Norms {idx}\")\n",
    "    plt.plot(np.linalg.norm(I_AB, axis=0), label=f\"Column Norms {idx}\", linestyle='--')\n",
    "plt.title(\"Information Tensor Norm Profiles\")\n",
    "plt.legend()\n",
    "\n",
    "# 3. Directional Coherence\n",
    "plt.subplot(2, 2, 3)\n",
    "coherence_values = [tensor_result['coherence_AB'] for tensor_result in tensor_interactions]\n",
    "plt.bar(range(len(coherence_values)), coherence_values)\n",
    "plt.title(\"Directional Coherence Across Interactions\")\n",
    "plt.xlabel(\"Interaction Index\")\n",
    "plt.ylabel(\"Coherence Magnitude\")\n",
    "\n",
    "# 4. Singular Value Distribution\n",
    "plt.subplot(2, 2, 4)\n",
    "for tensor_result in tensor_interactions:\n",
    "    plt.plot(tensor_result['singular_values_AB'], marker='o')\n",
    "plt.title(\"Singular Value Spectrum\")\n",
    "plt.xlabel(\"Singular Value Index\")\n",
    "plt.ylabel(\"Magnitude\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]

   "source": [
    "# Comprehensive Interaction Simulation\n",
    "def run_casp_simulation(n_dim=4, complexity=0.5):\n",
    "    # Generate Symmetric Signature Matrices\n",
    "    A_sig = np.random.rand(n_dim, n_dim)\n",
    "    A_sig = 0.5 * (A_sig + A_sig.T)\n",
    "    B_sig = np.random.rand(n_dim, n_dim)\n",
    "    B_sig = 0.5 * (B_sig + B_sig.T)\n",
    "\n",
    "    # Create Absolute Entities\n",
    "    A = AbsoluteEntity(A_sig, np.random.rand(n_dim))\n",
    "    B = AbsoluteEntity(B_sig, np.random.rand(n_dim))\n",
    "\n",
    "    # Construct Mediator with Controlled Complexity\n",
    "    M = construct_mediator(n_dim, n_dim, complexity)\n",
    "\n",
    "    # Evaluate CASP\n",
    "    results = evaluate_casp(A, B, M)\n",
    "\n",
    "    # Visualization and Reporting\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    sns.heatmap(\n",
    "        A.signature @ M @ B.signature.T, \n",
    "        cmap='magma', \n",
    "        annot=True, \n",
    "        fmt='.4f', \n",
    "        cbar_kws={'label': 'Entropy-Encoded Coupling'}\n",
    "    )\n",
    "    plt.title(\"Information Tensor: Source Space vs Target Space\", fontsize=12)\n",
    "    plt.xlabel(\"Target Space Axis j\", fontsize=10)\n",
    "    plt.ylabel(\"Source Space Axis i\", fontsize=10)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # Print Results\n",
    "    print(\"🔬 CASP Interaction Analysis\")\n",
    "    print(f\"Interaction Type: {results['InteractionType']}\")\n",
    "    print(f\"Interaction Action: {results['Action']:.4f}\")\n",
    "    print(f\"Entropy Leak: {results['EntropyLeak']:.4f}\")\n",
    "    print(f\"Coherence Index: {results['CoherenceIndex']:.4f}\")\n",
    "\n",
    "# Run Simulation\n",
    "run_casp_simulation()"
   ]
  },

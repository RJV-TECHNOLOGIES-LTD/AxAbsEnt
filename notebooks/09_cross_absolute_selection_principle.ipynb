     "name": "stdout",
     "output_type": "stream",
     "text": [
      "🔬 CASP Interaction Analysis:\n",
      "Interaction Type: Partial Alignment\n",
      "Interaction Action: 1.0277\n",
      "Entropy Leak: 0.0000\n",
      "Directional Coherence: 0.7256\n",
      "State Alignment: 0.4103\n"
     ]

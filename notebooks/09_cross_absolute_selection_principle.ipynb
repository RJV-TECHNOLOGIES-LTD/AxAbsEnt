   "source": [
    "# Information Tensor Visualization\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.heatmap(\n",
    "    results['InformationTensor'], \n",
    "    cmap='magma', \n",
    "    annot=True, \n",
    "    fmt='.4f', \n",
    "    cbar_kws={\n",
    "        'label': 'Entropy-Encoded Coupling',\n",
    "        'orientation': 'vertical'\n",
    "    }\n",
    ")\n",
    "plt.title(\"Information Tensor: Cross-Absolute Interaction Projection\", fontsize=12)\n",
    "plt.xlabel(\"Target Space Axis j\", fontsize=10)\n",
    "plt.ylabel(\"Source Space Axis i\", fontsize=10)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "symbolic-representation",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Symbolic CASP Action Representation:\n",
      "Trace(S1 * M * S2.T * S2 * M.T * S1.T)\n"
     ]
    }
   ],
   "source": [
    "# Symbolic Representation for Theoretical Exploration\n",
    "n = sp.Symbol('n', integer=True)\n",
    "S1 = sp.MatrixSymbol('S1', n, n)\n",
    "S2 = sp.MatrixSymbol('S2', n, n)\n",
    "M = sp.MatrixSymbol('M', n, n)\n",
    "\n",
    "# Symbolic CASP Action Computation\n",
    "symbolic_action = sp.trace(S1 * M * sp.Transpose(S2) * S2 * sp.Transpose(M) * sp.Transpose(S1))\n",
    "\n",
    "print(\"Symbolic CASP Action Representation:\")\n",
    "print(symbolic_action)"
   ]
  },
  {
   "cell_type": "markdown",

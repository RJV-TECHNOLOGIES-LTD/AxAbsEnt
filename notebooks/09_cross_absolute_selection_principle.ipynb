   "source": [
    "# Comprehensive Visualization Suite\n",
    "\n",
    "# Interaction Metrics Heatmap\n",
    "plt.figure(figsize=(10, 6))\n",
    "metric_names = ['InteractionAction', 'EntropyLeak', 'CoherenceIndex']\n",
    "\n",
    "metrics_matrix = np.array([\n",
    "    [casp_results[comp][metric] for metric in metric_names]\n",
    "    for comp in complexity_values\n",
    "])\n",
    "\n",
    "sns.heatmap(\n",
    "    metrics_matrix, \n",
    "    annot=True, \n",
    "    cmap='viridis', \n",
    "    xticklabels=metric_names,\n",
    "    yticklabels=[f'Complexity {c}' for c in complexity_values],\n",
    "    fmt='.4f'\n",
    ")\n",
    "plt.title(\"CASP Metrics Across Mediator Complexities\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 3D Visualization of Action Space\n",
    "plt.figure(figsize=(10, 8))\n",
    "from mpl_toolkits.mplot3d import Axes3D\n",
    "\n",
    "fig = plt.figure()\n",
    "ax = fig.add_subplot(111, projection='3d')\n",
    "\n",
    "ax.scatter(\n",
    "    [r['InteractionAction'] for r in casp_results.values()],\n",
    "    [r['EntropyLeak'] for r in casp_results.values()],\n",
    "    [r['CoherenceIndex'] for r in casp_results.values()],\n",
    "    c=['red', 'green', 'blue'],\n",
    "    marker='o'\n",
    ")\n",
    "\n",
    "ax.set_xlabel('Interaction Action')\n",
    "ax.set_ylabel('Entropy Leak')\n",
    "ax.set_zlabel('Coherence Index')\n",
    "ax.set_title('3D CASP Interaction Space')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]

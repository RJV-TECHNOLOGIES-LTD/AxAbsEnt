   "source": [
    "# Symbolic Representation for Theoretical Exploration\n",
    "n = sp.Symbol('n', integer=True, positive=True)\n",
    "S1, S2, M = sp.MatrixSymbol('S1', n, n), sp.MatrixSymbol('S2', n, n), sp.MatrixSymbol('M', n, n)\n",
    "\n",
    "# Symbolic Action Computation\n",
    "symbolic_action = sp.trace(S1 * M * sp.Transpose(S2) * S2 * sp.Transpose(M) * sp.Transpose(S1))\n",
    "\n",
    "print(f\"Symbolic Action Expression: {symbolic_action}\")"
   ]

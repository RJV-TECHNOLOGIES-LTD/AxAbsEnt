   ],
   "source": [
    "# Comprehensive Simulation Configuration\n",
    "np.random.seed(42)  # Reproducible randomness\n",
    "\n",
    "# Generate Absolute Entities with Named Contexts\n",
    "A_sig = np.random.rand(4, 4)\n",
    "A_sig = 0.5 * (A_sig + A_sig.T)  # Symmetric\n",
    "B_sig = np.random.rand(4, 4)\n",
    "B_sig = 0.5 * (B_sig + B_sig.T)  # Symmetric\n",
    "\n",
    "A = AbsoluteEntity(A_sig, np.random.rand(4), name=\"Source Entity\")\n",
    "B = AbsoluteEntity(B_sig, np.random.rand(4), name=\"Target Entity\")\n",
    "\n",
    "# Optimize Mediator\n",
    "optimized_mediator = optimize_casp_mediator(A, B)\n",
    "\n",
    "# Evaluate CASP with Optimized Mediator\n",
    "results = evaluate_casp(A, B, optimized_mediator)\n",
    "\n",
    "# Detailed Metrics Reporting\n",
    "print(\"🔬 CASP Interaction Analysis:\")\n",
    "print(f\"Interaction Type: {results['InteractionType']}\")\n",
    "print(f\"Interaction Action: {results['InteractionAction']:.4f}\")\n",
    "print(f\"Entropy Leak: {results['EntropyLeak']:.4f}\")\n",
    "print(f\"Directional Coherence: {results['DirectionalCoherence']:.4f}\")\n",
    "print(f\"State Alignment: {results['StateAlignment']:.4f}\")"
   ]
  },

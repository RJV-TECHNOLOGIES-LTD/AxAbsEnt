   ],
   "source": [
    "# Symbolic Representation for Theoretical Exploration\n",
    "n = 4  # Dimension of matrices\n",
    "S1, S2, M = sp.MatrixSymbol('S1', n, n), sp.MatrixSymbol('S2', n, n), sp.MatrixSymbol('M', n, n)\n",
    "\n",
    "# Symbolic Action Computation\n",
    "action_tensor = sp.trace(S1 * M * sp.Transpose(S2) * S2 * sp.Transpose(M) * sp.Transpose(S1))\n",
    "\n",
    "print(\"Symbolic CASP Representation:\")\n",
    "print(f\"Action Tensor: {action_tensor}\")"
   ]
  },

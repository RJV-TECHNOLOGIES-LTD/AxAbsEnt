# =========================================
# AxAbsEnt – .gitignore (Full Coverage)
# =========================================

# ----------------------
# Python Artifacts
# ----------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.so
*.egg
*.egg-info/
*.log

# Byte-compiled, test coverage, profiling
.coverage
.cache/
.tox/
.mypy_cache/
.pytest_cache/
nosetests.xml
test-results.xml
htmlcov/
*.prof

# Virtual environments
.venv/
venv/
env/
ENV/

# ----------------------
# Jupyter Notebooks
# ----------------------
.ipynb_checkpoints/
*.nbconvert.ipynb
notebooks/**/output/
**/.ipynb_checkpoints/

# ----------------------
# Documentation
# ----------------------
docs/_build/
docs/_static/diagrams/
docs/build/
build/

# Sphinx / Make artifacts
*.pdf
*.tex
*.aux
*.out
*.toc
*.log

# ----------------------
# Data & Simulation Artifacts
# ----------------------
data/**/*.csv
data/**/*.hdf5
data/**/*.nc
data/**/*.json
data/**/*.pkl
data/**/*.npy
data/**/*.npz
data/**/*.parquet
data/experimental/
data/simulation/

# DO NOT IGNORE curated reference data
!data/constants/
!data/reference/

# ----------------------
# Compiled / C++ / CUDA
# ----------------------
*.o
*.obj
*.a
*.lib
*.dll
*.exe
*.out
*.app
*.dylib
*.pdb
*.exp
*.mod

# CMake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
CMakeLists.txt.user
build/
cpp/build/
cpp/lib/

# ----------------------
# Node / Web Frontend
# ----------------------
node_modules/
web/node_modules/
web/dist/
web/build/
web/.next/
web/.parcel-cache/
web/yarn.lock
web/package-lock.json
*.lock

# ----------------------
# Docker & Kubernetes
# ----------------------
*.pid
*.tar
*.sock
docker-compose.override.yml
.env
.env.*
.DS_Store

# ----------------------
# Logs, Experiments, Outputs
# ----------------------
logs/
output/
output.log
experiments/
*.checkpoint
*.ckpt

# ----------------------
# Editors and IDEs
# ----------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ----------------------
# OS / File System
# ----------------------
Thumbs.db
.DS_Store
ehthumbs.db
Icon?
desktop.ini

# =========================================
# END OF AxAbsEnt .gitignore
# =========================================
